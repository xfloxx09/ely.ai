generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RETAIL
  AFFILIATE
  ADMIN
}

enum Plan {
  FREE
  PLUS
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum Rank {
  EXPLORER
  BUILDER
  INNOVATOR
  VISIONARY
  MASTERMIND
  ELITE_MASTERMIND
}

enum CommissionType {
  FAST_START
  RESIDUAL
  UNILEVEL_L1
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

enum AiModule {
  CONCIERGE
  CONTENT
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  name               String?
  passwordHash       String?
  image              String?
  role               UserRole  @default(RETAIL)
  rank               Rank      @default(EXPLORER)
  referralCode       String    @unique
  sponsorId          String?
  sponsor            User?     @relation("Sponsorship", fields: [sponsorId], references: [id])
  referrals          User[]    @relation("Sponsorship")
  stripeCustomerId   String?   @unique
  xp                 Int       @default(0)
  streak             Int       @default(0)
  lastQuestDate      String?
  dailyTaskCount     Int       @default(0)
  firstInvoicePaid   Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  subscription       Subscription?
  ancestorClosures   GenealogyClosure[] @relation("DescendantClosures")
  descendantClosures GenealogyClosure[] @relation("AncestorClosures")
  commissionsEarned  CommissionLedger[] @relation("Earner")
  commissionsSource  CommissionLedger[] @relation("Source")
  aiUsage            AiUsage[]
  chatMessages       ChatMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model GenealogyClosure {
  ancestorId   String
  descendantId String
  depth        Int
  ancestor     User @relation("AncestorClosures", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant   User @relation("DescendantClosures", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@index([descendantId])
  @@index([ancestorId, depth])
}

model CommissionLedger {
  id           String           @id @default(cuid())
  userId       String
  sourceUserId String
  type         CommissionType
  amountCents  Int
  period       String
  status       CommissionStatus @default(PENDING)
  description  String?
  createdAt    DateTime         @default(now())

  user   User @relation("Earner", fields: [userId], references: [id], onDelete: Cascade)
  source User @relation("Source", fields: [sourceUserId], references: [id], onDelete: Cascade)

  @@index([userId, period])
  @@index([sourceUserId])
}

model AiUsage {
  id           String   @id @default(cuid())
  userId       String
  date         String
  messageCount Int      @default(0)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  module    AiModule
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
